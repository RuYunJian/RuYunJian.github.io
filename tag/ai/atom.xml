&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;SFT&lt;/td&gt;
&lt;td&gt;Supervised Fine-tuning&lt;/td&gt;
&lt;td&gt;监督微调&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;RLHF&lt;/td&gt;
&lt;td&gt;Reinforcement Learning from Human Feedback&lt;/td&gt;
&lt;td&gt;基于人类反馈的强化学习&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;PII&lt;/td&gt;
&lt;td&gt;Personally Identifiable Information&lt;/td&gt;
&lt;td&gt;个人身份识别信息&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Eval&lt;/td&gt;
&lt;td&gt;Evaluation&lt;/td&gt;
&lt;td&gt;评估&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;UI&lt;/td&gt;
&lt;td&gt;User Interface&lt;/td&gt;
&lt;td&gt;用户界面&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;UX&lt;/td&gt;
&lt;td&gt;User Experience&lt;/td&gt;
&lt;td&gt;用户体验&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;h2 id=&#34;15-容易混淆的概念&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#15-容易混淆的概念&#34;&gt;#&lt;/a&gt; 15. 容易混淆的概念&lt;/h2&gt;
&lt;h3 id=&#34;api-sdk-mcp-的区别&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#api-sdk-mcp-的区别&#34;&gt;#&lt;/a&gt; API、SDK、MCP 的区别&lt;/h3&gt;
&lt;table&gt;
&lt;thead&gt;
&lt;tr&gt;
&lt;th&gt;概念&lt;/th&gt;
&lt;th&gt;简单理解&lt;/th&gt;
&lt;th&gt;作用&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td&gt;API&lt;/td&gt;
&lt;td&gt;服务提供的接口&lt;/td&gt;
&lt;td&gt;让程序能调用某项能力&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;SDK&lt;/td&gt;
&lt;td&gt;封装好的开发工具包&lt;/td&gt;
&lt;td&gt;让开发者更方便地调用 API&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;MCP&lt;/td&gt;
&lt;td&gt;连接 AI 与工具/数据源的协议&lt;/td&gt;
&lt;td&gt;让 AI 应用标准化访问外部能力&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;token-字符-单词的区别&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#token-字符-单词的区别&#34;&gt;#&lt;/a&gt; Token、字符、单词的区别&lt;/h3&gt;
&lt;table&gt;
&lt;thead&gt;
&lt;tr&gt;
&lt;th&gt;概念&lt;/th&gt;
&lt;th&gt;说明&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td&gt;字符&lt;/td&gt;
&lt;td&gt;人类看到的单个文字、字母、数字或符号&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;单词&lt;/td&gt;
&lt;td&gt;自然语言中的词&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Token&lt;/td&gt;
&lt;td&gt;模型处理文本的基本单位，可能是字、词、词的一部分或符号&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;prompt-context-memory-的区别&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#prompt-context-memory-的区别&#34;&gt;#&lt;/a&gt; Prompt、Context、Memory 的区别&lt;/h3&gt;
&lt;table&gt;
&lt;thead&gt;
&lt;tr&gt;
&lt;th&gt;概念&lt;/th&gt;
&lt;th&gt;说明&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td&gt;Prompt&lt;/td&gt;
&lt;td&gt;当前给模型的任务指令&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Context&lt;/td&gt;
&lt;td&gt;当前调用中模型能看到的全部上下文&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Memory&lt;/td&gt;
&lt;td&gt;跨对话或长期保存的信息&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;tool-skill-plugin-的区别&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#tool-skill-plugin-的区别&#34;&gt;#&lt;/a&gt; Tool、Skill、Plugin 的区别&lt;/h3&gt;
&lt;table&gt;
&lt;thead&gt;
&lt;tr&gt;
&lt;th&gt;概念&lt;/th&gt;
&lt;th&gt;简单理解&lt;/th&gt;
&lt;th&gt;示例&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td&gt;Tool&lt;/td&gt;
&lt;td&gt;一个可执行能力&lt;/td&gt;
&lt;td&gt;搜索网页、读文件、查数据库&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Skill&lt;/td&gt;
&lt;td&gt;一套完成任务的方法&lt;/td&gt;
&lt;td&gt;数据分析流程、PPT 制作流程&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Plugin&lt;/td&gt;
&lt;td&gt;一组可安装扩展&lt;/td&gt;
&lt;td&gt;包含工具、技能、配置和资源&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;training-fine-tuning-inference-的区别&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#training-fine-tuning-inference-的区别&#34;&gt;#&lt;/a&gt; Training、Fine-tuning、Inference 的区别&lt;/h3&gt;
&lt;table&gt;
&lt;thead&gt;
&lt;tr&gt;
&lt;th&gt;概念&lt;/th&gt;
&lt;th&gt;说明&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td&gt;Training&lt;/td&gt;
&lt;td&gt;从大量数据中训练模型&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Fine-tuning&lt;/td&gt;
&lt;td&gt;在已有模型基础上针对特定场景继续训练&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Inference&lt;/td&gt;
&lt;td&gt;使用训练好的模型生成结果&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;h2 id=&#34;16-实用建议&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#16-实用建议&#34;&gt;#&lt;/a&gt; 16. 实用建议&lt;/h2&gt;
&lt;h3 id=&#34;使用-ai-api-时&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#使用-ai-api-时&#34;&gt;#&lt;/a&gt; 使用 AI API 时&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;保护 API Key，不要公开&lt;/li&gt;
&lt;li&gt;控制输入和输出 token，避免成本失控&lt;/li&gt;
&lt;li&gt;对关键任务设置日志和错误处理&lt;/li&gt;
&lt;li&gt;高风险内容要加入人工审核&lt;/li&gt;
&lt;li&gt;不要默认相信模型生成的事实&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id=&#34;写-prompt-时&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#写-prompt-时&#34;&gt;#&lt;/a&gt; 写 Prompt 时&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;明确目标&lt;/li&gt;
&lt;li&gt;给足背景&lt;/li&gt;
&lt;li&gt;说明输出格式&lt;/li&gt;
&lt;li&gt;提供好坏示例&lt;/li&gt;
&lt;li&gt;对复杂任务分步骤&lt;/li&gt;
&lt;li&gt;明确不允许做什么&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id=&#34;做知识库问答时&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#做知识库问答时&#34;&gt;#&lt;/a&gt; 做知识库问答时&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;优先保证文档质量&lt;/li&gt;
&lt;li&gt;合理切分 chunk&lt;/li&gt;
&lt;li&gt;使用 embedding 做语义检索&lt;/li&gt;
&lt;li&gt;对检索结果进行 reranking&lt;/li&gt;
&lt;li&gt;要求模型基于来源回答&lt;/li&gt;
&lt;li&gt;对答案提供引用或出处&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id=&#34;构建-agent-时&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#构建-agent-时&#34;&gt;#&lt;/a&gt; 构建 Agent 时&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;限制工具权限&lt;/li&gt;
&lt;li&gt;记录关键操作&lt;/li&gt;
&lt;li&gt;对写入、删除、支付、发消息等操作加确认&lt;/li&gt;
&lt;li&gt;给 Agent 明确目标和边界&lt;/li&gt;
&lt;li&gt;设计失败恢复机制&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id=&#34;17-延伸学习路线&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#17-延伸学习路线&#34;&gt;#&lt;/a&gt; 17. 延伸学习路线&lt;/h2&gt;
&lt;p&gt;如果从零开始学习 AI 工程，可以按下面顺序理解：&lt;/p&gt;
&lt;ol&gt;
&lt;li&gt;AI、机器学习、大语言模型是什么&lt;/li&gt;
&lt;li&gt;Prompt、Token、上下文窗口如何影响输出&lt;/li&gt;
&lt;li&gt;API、API Key、SDK 如何接入模型&lt;/li&gt;
&lt;li&gt;Tool Calling、Agent 如何让模型执行任务&lt;/li&gt;
&lt;li&gt;RAG、Embedding、向量数据库如何连接私有知识&lt;/li&gt;
&lt;li&gt;MCP、Skill、Plugin 如何扩展 AI 应用能力&lt;/li&gt;
&lt;li&gt;安全、隐私、权限、成本如何在真实项目中控制&lt;/li&gt;
&lt;li&gt;评估、监控、日志如何保障系统质量&lt;/li&gt;
&lt;/ol&gt;
</content>
